# ─────────────────────────────────────────────────────────────
# Resurrection Tech™ — environment variables
# Copy to `.env.local` for local dev. Set the same keys in Vercel.
# NEVER commit real secrets. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://resurrectiontech.ai

# ── Supabase ──────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Used by the API route to insert with elevated rights.
# Project Settings → API → service_role secret. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ── Email (Resend) ────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
# Must be a verified sending domain in Resend.
EMAIL_FROM="Resurrection Tech <audit@resurrectiontech.ai>"
# Internal recipient for new audit-request notifications.
AUDIT_NOTIFY_TO=audit@resurrectiontech.ai

# ── Scheduling (Calendly) ─────────────────────────────────────
NEXT_PUBLIC_CALENDLY_DISCOVERY=https://calendly.com/resurrectiontech/discovery-call
NEXT_PUBLIC_CALENDLY_REVIEW=https://calendly.com/resurrectiontech/runtime-governance-review
NEXT_PUBLIC_CALENDLY_SCOPING=https://calendly.com/resurrectiontech/enterprise-audit-scoping

# ── Analytics ─────────────────────────────────────────────────
# Google Analytics 4 measurement id (optional).
NEXT_PUBLIC_GA_ID=
# Plausible domain, e.g. resurrectiontech.ai (optional).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Spam / rate-limit tuning (optional) ───────────────────────
# Max audit submissions per IP per window.
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=600000

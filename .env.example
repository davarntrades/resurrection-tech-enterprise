# ─────────────────────────────────────────────────────────────
# Resurrection Tech™ — environment variables
# Copy to `.env.local` for local dev. Set the same keys in Vercel.
# NEVER commit real secrets. `.env.local` is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://resurrection-tech.com

# ── Supabase ──────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Used by the API route to insert with elevated rights.
# Project Settings → API → service_role secret. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ── Email (Resend) ────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
# Must be a verified sending domain in Resend.
EMAIL_FROM="Resurrection Tech <hello@resurrection-tech.com>"
# Internal recipient for new audit-request notifications.
AUDIT_NOTIFY_TO=hello@resurrection-tech.com
# Internal recipient for new booking/lead notifications (defaults to AUDIT_NOTIFY_TO).
LEAD_NOTIFY_TO=hello@resurrection-tech.com
# Internal recipient for Runtime Governance Assessment submissions
# (defaults to hello@resurrection-tech.com).
ASSESSMENT_NOTIFY_TO=hello@resurrection-tech.com

# ── Internal admin dashboard (/admin/leads) ───────────────────
# HTTP Basic Auth for the internal lead dashboard. If BOTH are unset the
# /admin area returns 404 (hidden). Set both to enable.
ADMIN_USER=
ADMIN_PASSWORD=

# ── Partner visibility links (/partner/[code]) ────────────────
# Secret used to sign per-partner visibility links generated from
# /admin/partners. A partner link is /partner/<code>?t=<hmac>; the token is an
# HMAC of the code with this secret, so codes cannot be guessed/enumerated and a
# partner can only ever see their own statistics. If unset, shareable partner
# links are disabled (the /admin/partners table still works). Use a long random
# value (e.g. `openssl rand -hex 32`).
PARTNER_LINK_SECRET=

# ── Lead capture (optional integration points) ────────────────
# Optional: forward leads to a Formspree form or any webhook (POST JSON).
# Leave unset to rely on Supabase/Resend (or local logging) instead.
LEAD_FORWARD_URL=

# ── Scheduling (Calendly) ─────────────────────────────────────
# Three booking options used across the site (/book, home, services,
# contact). These fall back to the live links in lib/booking.ts if unset;
# override here to point at different Calendly events per environment.
NEXT_PUBLIC_CALENDLY_DISCOVERY=https://calendly.com/davarn-resurrection-tech/30min
NEXT_PUBLIC_CALENDLY_ASSESSMENT=https://calendly.com/davarn-resurrection-tech/runtime-safety-assessment
NEXT_PUBLIC_CALENDLY_STRATEGY=https://calendly.com/davarn-resurrection-tech/enterprise-ai-governance-strategy-session
# Paid Discovery Workshop (invoice-only scoping engagement). Optional — falls
# back to the strategy session link until a dedicated event is configured.
NEXT_PUBLIC_CALENDLY_WORKSHOP=

# ── Analytics ─────────────────────────────────────────────────
# Google Analytics 4 measurement id (optional).
NEXT_PUBLIC_GA_ID=
# Plausible domain, e.g. resurrection-tech.com (optional).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Spam / rate-limit tuning (optional) ───────────────────────
# Max audit submissions per IP per window.
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=600000

# ── Payments — Stripe (card, Apple/Google Pay via hosted Checkout) ──
# Server-only secret key (sk_live_… / sk_test_…). NEVER expose to the client.
STRIPE_SECRET_KEY=
# Publishable key (pk_live_… / pk_test_…). Safe for the browser. Reserved for
# future client-side use; hosted Checkout does not require it server-side.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_…) for /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=

# ── Payments — GoCardless (Direct Debit / bank debit) ──
# Access token (server-only).
GOCARDLESS_ACCESS_TOKEN=
# Webhook secret for /api/webhooks/gocardless.
GOCARDLESS_WEBHOOK_SECRET=
# "sandbox" (default) or "live".
GOCARDLESS_ENVIRONMENT=sandbox

# ── Runtime Governance service (Custom Evaluation backend) ──
# Base URL of the Morrison governance FastAPI service (see governance-service/).
# Defaults in code to the live Railway deployment below; set this to override,
# or to "" to disable and use the in-process heuristic fallback.
GOVERNANCE_URL=https://resurrection-tech-enterprise-production.up.railway.app
# Bearer token; must match the service's GOVERNANCE_TOKEN. Leave blank only if
# the service has auth disabled; required (and matching) if it enforces auth.
GOVERNANCE_TOKEN=
# Client-side abort (ms) before falling back to the heuristic. Default 4000.
GOVERNANCE_TIMEOUT_MS=4000

# ── Hugging Face planner (Generate Your Own Scenario) ──
# Server-only token used by /api/plan-and-evaluate to run the SAME open-weight
# planner as the Colab smoke test via the HF Inference router. If unset, the
# "Generate your own scenario" demo falls back to a transparent keyword planner
# (clearly labelled in the UI); the governance verdict still comes from the live
# engine. NEVER expose this token to the browser.
HF_API_TOKEN=
# Planner model id (HF Inference router). Default: Qwen/Qwen2.5-0.5B-Instruct.
PLANNER_MODEL=Qwen/Qwen2.5-0.5B-Instruct

# Resurrection Tech — Delivery Kit config.
# Copy to `.env.delivery` (gitignored) so analysts never re-export each session.
#   cp .env.delivery.example .env.delivery   then fill in the token.

# Runtime Governance engine (defaults to the live Railway service if unset).
GOVERNANCE_URL=https://resurrection-tech-enterprise-production.up.railway.app
# Bearer token for /v1/evaluate. Required for the executive-report replay.
GOVERNANCE_TOKEN=

# Optional: pin Chromium if auto-discovery can't find it.
# CHROME_BIN=/usr/bin/chromium

# Report PDF style: "dark" (default brand) or "editorial" (light Pagella house
# style). The console picks this up for every audit it renders.
# RT_PDF_STYLE=editorial

# Analyst Console (npm run console) — REQUIRED to start the console (fail-closed).
# Only authenticated analysts reach the console; customers never do.
#   generate a strong password:
#   node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
ANALYST_USER=
ANALYST_PASSWORD=
# Optional: console bind (defaults to 127.0.0.1:8787 — keep it local/private).
# CONSOLE_PORT=8787
# CONSOLE_HOST=127.0.0.1
